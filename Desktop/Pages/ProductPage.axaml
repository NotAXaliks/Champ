<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Desktop.Pages.ProductPage"
        d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <Button>Создать продукт</Button>

        <DataGrid IsReadOnly="True" Name="ProductsGrid" SelectionMode="Single" AutoGenerateColumns="False" CanUserSortColumns="True" DoubleTapped="ClickProduct">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код продукта" Binding="{Binding Product.Code}" />    
                <DataGridTextColumn Header="Имя" Binding="{Binding Product.Name}" />    
                <DataGridTextColumn Header="Тип" Binding="{Binding Product.Type.Name}" />    
                <DataGridTextColumn Header="Форма выпуска" Binding="{Binding Product.Form.Name}" />    
                <DataGridTextColumn Header="Статус" Binding="{Binding Product.Status.Name}" />    
                <DataGridTextColumn Header="Рецептура" Binding="{Binding Recipe.Id}" />    
                <DataGridTextColumn Header="Техкарта" Binding="{Binding TechCard.Id}" />    
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl> 